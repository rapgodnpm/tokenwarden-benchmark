{
  "id": "openrtk",
  "label": "OpenRTK",
  "plugins": ["openrtk"],
  "npmPackages": ["openrtk"],
  "binaries": [
    {
      "name": "rtk",
      "source": "github-release",
      "repo": "rtk-ai/rtk",
      "assetByPlatform": {
        "darwin-arm64": "rtk-aarch64-apple-darwin.tar.gz",
        "darwin-x64": "rtk-x86_64-apple-darwin.tar.gz",
        "linux-arm64": "rtk-aarch64-unknown-linux-gnu.tar.gz",
        "linux-x64": "rtk-x86_64-unknown-linux-musl.tar.gz"
      }
    }
  ],
  "notes": "OpenRTK opencode plugin enabled only. RTK binary is installed from the rtk-ai/rtk GitHub release when running a real benchmark."
}
