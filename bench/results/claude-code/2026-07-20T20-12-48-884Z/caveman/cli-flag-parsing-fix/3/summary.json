      "content": "export function parseArgs(argv) {\n  const result = { _: [] }\n  for (let i = 0; i < argv.length; i += 1) {\n    const arg = argv[i]\n    if (!arg.startsWith('--')) {\n      result._.push(arg)\n      continue\n    }\n    if (arg.includes('=')) {\n      const [key, value] = arg.slice(2).split('=', 2)\n      result[key] = value\n    } else if (i + 1 < argv.length && !argv[i + 1].startsWith('--')) {\n      result[arg.slice(2)] = argv[i + 1]\n      i += 1\n    } else {\n      result[arg.slice(2)] = true\n    }\n  }\n  return result\n}\n"
