      "path": "bench-targets/cli-flags/src/parseArgs.mjs",
      "content": "export function parseArgs(argv) {\n  const result = { _: [] }\n\n  for (let i = 0; i < argv.length; i++) {\n    const arg = argv[i]\n\n    // Positional argument (doesn't start with --)\n    if (!arg.startsWith('--')) {\n      result._.push(arg)\n      continue\n    }\n\n    // --key=value syntax\n    if (arg.includes('=')) {\n      const eqIndex = arg.indexOf('=')\n      const key = arg.slice(0, eqIndex).slice(2)\n      const value = arg.slice(eqIndex + 1)\n      result[key] = value\n      continue\n    }\n\n    const key = arg.slice(2)\n\n    // --key value syntax (next arg is the value)\n    if (i + 1 < argv.length && !argv[i + 1].startsWith('--')) {\n      result[key] = argv[i + 1]\n      i += 1\n      continue\n    }\n\n    // --key flag\n    result[key] = true\n  }\n\n  return result\n}\n"
    }
