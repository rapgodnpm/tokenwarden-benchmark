      "content": "export function parseArgs(argv) {\n  const result = { _: [] }\n  let i = 0\n  while (i < argv.length) {\n    const arg = argv[i]\n    if (!arg.startsWith('--')) {\n      result._.push(arg)\n      i += 1\n    } else if (arg.includes('=')) {\n      // --key=value syntax\n      const [key, value] = arg.split('=', 2)\n      result[key.slice(2)] = value\n      i += 1\n    } else {\n      // --flag or --key (value follows)\n      const key = arg.slice(2)\n      if (i + 1 < argv.length && !argv[i + 1].startsWith('-')) {\n        // --key value syntax\n        result[key] = argv[i + 1]\n        i += 2\n      } else {\n        // --flag boolean\n        result[key] = true\n        i += 1\n      }\n    }\n  }\n  return result\n}\n"
    }
