{
  "$schema": "https://opencode.ai/config.json",
  "lsp": false,
  "model": "lmstudio/qwen/qwen3.5-9b",
  "small_model": "lmstudio/qwen/qwen3.5-9b",
  "plugin": [
    "openrtk"
  ],
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen/qwen3.5-9b": {
          "name": "qwen/qwen3.5-9b",
          "limit": {
            "context": 128000,
            "output": 4096
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "lmstudio-local2": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio Local22",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen3.6-35b-a3b-mlx": {
          "name": "qwen3.6-35b-a3b-mlx",
          "limit": {
            "context": 128000,
            "output": 4096
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "lmstudio-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio Local",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen/qwen3.6-27b": {
          "name": "qwen/qwen3.6-27b",
          "limit": {
            "context": 128000,
            "output": 2048
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  }
}
