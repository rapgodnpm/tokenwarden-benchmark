{
  "name": "tokenwarden-benchmark",
  "version": "0.1.0",
  "description": "Reproducible opencode benchmark harness and public TokenWarden result summaries.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "node bench/run-opencode-benchmark.mjs",
    "bench:prepare": "node bench/run-opencode-benchmark.mjs --prepare-only",
    "bench:dry": "node bench/run-opencode-benchmark.mjs --dry-run",
    "bench:report": "node bench/report.mjs",
    "test": "node --test bench/tests/*.test.mjs"
  }
}
