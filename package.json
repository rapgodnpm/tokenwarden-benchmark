{
  "name": "tokenwarden-benchmark",
  "version": "0.1.0",
  "description": "Reproducible OpenCode and Claude Code benchmark harness with public TokenWarden result summaries.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "bench:opencode": "node bench/run-opencode-benchmark.mjs",
    "bench:opencode:prepare": "node bench/run-opencode-benchmark.mjs --prepare-only",
    "bench:opencode:dry": "node bench/run-opencode-benchmark.mjs --dry-run",
    "bench:claude-code": "node bench/run-claude-code-benchmark.mjs",
    "bench:claude-code:prepare": "node bench/run-claude-code-benchmark.mjs --prepare-only",
    "bench:claude-code:dry": "node bench/run-claude-code-benchmark.mjs --dry-run",
    "bench:report:opencode": "node bench/report.mjs --platform opencode",
    "bench:report:claude-code": "node bench/report.mjs --platform claude-code",
    "test": "node --test bench/tests/*.test.mjs"
  }
}
